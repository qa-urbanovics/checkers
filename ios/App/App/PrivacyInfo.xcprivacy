<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

  <!-- Does the app use data for tracking? NO -->
  <key>NSPrivacyTracking</key>
  <false/>

  <!-- Domains used for tracking — none -->
  <key>NSPrivacyTrackingDomains</key>
  <array/>

  <!-- Data types collected — none -->
  <key>NSPrivacyCollectedDataTypes</key>
  <array/>

  <!-- Required Reason APIs used by the app -->
  <key>NSPrivacyAccessedAPITypes</key>
  <array>

    <!--
      UserDefaults (NSUserDefaults)
      Used by Capacitor to persist app settings and game stats via localStorage.
      Reason CA92.1: reading/writing data from the same app only, not shared externally.
    -->
    <dict>
      <key>NSPrivacyAccessedAPIType</key>
      <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
      <key>NSPrivacyAccessedAPITypeReasons</key>
      <array>
        <string>CA92.1</string>
      </array>
    </dict>

  </array>

</dict>
</plist>
